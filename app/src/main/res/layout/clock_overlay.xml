<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clock_overlay_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="end|center_vertical"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingEnd="6dp">

    <TextView
        android:id="@+id/timer_tab"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/terminal_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="4dp"
        android:drawableTop="@drawable/timer_24"
        android:drawablePadding="2dp"
        android:text="--:--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/stopwatch_tab"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/terminal_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="4dp"
        android:drawableTop="@drawable/hourglass_24"
        android:drawablePadding="2dp"
        android:text="--:--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
